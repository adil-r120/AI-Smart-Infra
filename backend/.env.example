# Smart-Infra v2 Environment Configuration
# Copy this to .env and fill in the values

# --- Security ---
# Generated via: openssl rand -hex 32
JWT_SECRET=smart-infra-production-secret-replace-me
# Optional: required to create admin accounts during signup.
# Leave unset to disable self-service admin signup.
ADMIN_SIGNUP_CODE=replace-with-long-random-admin-code
# Admin invite token lifetime in hours
ADMIN_INVITE_TTL_HOURS=24
# Signup rate limiting
REGISTER_RATE_LIMIT_MAX_ATTEMPTS=10
REGISTER_RATE_LIMIT_WINDOW_SECONDS=60

# --- Database ---
DATABASE_URL=mysql+pymysql://root:Password@123@127.0.0.1:3306/smart_infra

# --- AI Configuration ---
# Confidence threshold for YOLO detection (0.0 to 1.0)
DETECTION_THRESHOLD=0.45

# --- Networking ---
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Google OAuth (Optional) ---
# GOOGLE_CLIENT_ID=your-id-here
